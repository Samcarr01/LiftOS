# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dashboard → Project Settings → API → service_role (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard URL slug + DB password (used by Supabase CLI)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password

# Personal access token → supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-access-token

# ── AI ────────────────────────────────────────────────────────────────────────
# Server-side only — used by Edge Functions, never exposed to client
OPENAI_API_KEY=sk-your-key-here

# ── Analytics & Monitoring (optional) ────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
