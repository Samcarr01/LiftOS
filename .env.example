# ── Supabase – client (EXPO_PUBLIC_ required for Expo to bundle these) ────────
# API URL format:  https://<project-ref>.supabase.co   ← NOT the dashboard URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase – server / CLI (never exposed to the client) ─────────────────────
# Project ref: the 20-char slug in your Supabase dashboard URL
#   e.g. https://supabase.com/dashboard/project/abcdefghijklmnopqrst
SUPABASE_PROJECT_REF=your-project-ref

# Personal access token – create at https://supabase.com/dashboard/account/tokens
# Used by: `supabase link`, `supabase db push`, `supabase functions deploy`
SUPABASE_ACCESS_TOKEN=your-access-token

# Direct DB password (set when you created the project)
# Used by: `supabase db reset`, direct psql connections, pg_dump
SUPABASE_DB_PASSWORD=your-db-password

# Service role key – bypasses ALL RLS. NEVER expose to the client or commit to git.
# Find it: Dashboard → Project Settings → API → service_role (secret)
# Used by: Edge Functions that need admin DB access (seed exercises, weekly summaries)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic – server-side only (Edge Functions). NEVER expose to client.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI – server-side only (Edge Functions). NEVER expose to client.
OPENAI_API_KEY=sk-your-key-here

# PostHog analytics (optional)
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (optional)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
